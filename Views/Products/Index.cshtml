@model IEnumerable<IMS.Models.Product>

@{
    ViewData["Title"] = "Products";
    var isManager = User.IsInRole("Manager");

    // Distinct categories for filter dropdown
    var categories = Model
        .Select(p => p.Category)
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct()
        .OrderBy(c => c)
        .ToList();
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="text-white mb-1">Products</h2>
        <div class="ims-muted">Manage your inventory and monitor stock levels.</div>
    </div>

    @if (isManager)
    {
        <a class="btn btn-primary" asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>Add Product
        </a>
    }
</div>

<div class="card ims-card p-3 p-md-4">
    <div class="row g-2 align-items-end mb-3">
        <div class="col-md-5">
            <label class="form-label ims-muted small">Search</label>
            <input id="productSearch" class="form-control" placeholder="Search by name or category..." />
        </div>

        <div class="col-md-4">
            <label class="form-label ims-muted small">Category</label>
            <select id="categoryFilter" class="form-select">
                <option value="">All categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="button" class="btn btn-outline-light w-100" id="clearFilters">
                <i class="bi bi-x-circle me-1"></i>Clear
            </button>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="ims-pill text-white">
            <i class="bi bi-box-seam me-1"></i>Total: <span id="countTotal">@Model.Count()</span>
        </span>
        <span class="ims-pill text-white">
            <i class="bi bi-exclamation-triangle me-1"></i>Low stock: <span id="countLow">@Model.Count(p => p.Quantity <= p.Threshold)</span>
        </span>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0" id="productsTable">
            <thead>
                <tr>
                    <th style="min-width: 200px;">Product</th>
                    <th style="min-width: 140px;">Category</th>
                    <th class="text-end" style="min-width: 120px;">Unit Price</th>
                    <th class="text-end" style="min-width: 90px;">Qty</th>
                    <th class="text-end" style="min-width: 110px;">Threshold</th>
                    <th style="min-width: 120px;">Status</th>
                    <th class="text-end" style="min-width: 190px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderBy(p => p.Name))
                {
                    var isLow = item.Quantity <= item.Threshold;

                    <tr data-name="@item.Name.ToLower()"
                        data-category="@item.Category"
                        data-category-lower="@item.Category.ToLower()">
                        <td>
                            <div class="fw-semibold text-white">@item.Name</div>
                            <div class="ims-muted small">ID: @item.ProductID</div>
                        </td>
                        <td>@item.Category</td>
                        <td class="text-end">@item.UnitPrice.ToString("0.00")</td>
                        <td class="text-end">@item.Quantity</td>
                        <td class="text-end">@item.Threshold</td>
                        <td>
                            @if (isLow)
                            {
                                <span class="badge rounded-pill bg-danger">
                                    <i class="bi bi-exclamation-triangle me-1"></i>LOW
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-success">
                                    <i class="bi bi-check2-circle me-1"></i>OK
                                </span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-light"
                               asp-action="Details"
                               asp-route-id="@item.ProductID">
                                <i class="bi bi-eye me-1"></i>View
                            </a>

                            @if (isManager)
                            {
                                <a class="btn btn-sm btn-outline-light ms-1"
                                   asp-action="Edit"
                                   asp-route-id="@item.ProductID">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>

                                <a class="btn btn-sm btn-outline-danger ms-1"
                                   asp-action="Delete"
                                   asp-route-id="@item.ProductID">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 ims-muted small">
        Tip: Stock quantity is updated automatically via Sales and Restocks.
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const searchInput = document.getElementById("productSearch");
            const categoryFilter = document.getElementById("categoryFilter");
            const clearBtn = document.getElementById("clearFilters");
            const table = document.getElementById("productsTable");
            const rows = Array.from(table.querySelectorAll("tbody tr"));

            const countTotal = document.getElementById("countTotal");
            const countLow = document.getElementById("countLow");

            function isLowStockRow(row) {
                // LOW badge exists
                return row.querySelector(".bg-danger") !== null;
            }

            function applyFilters() {
                const q = (searchInput.value || "").trim().toLowerCase();
                const cat = (categoryFilter.value || "").trim();

                let visible = 0;
                let lowVisible = 0;

                rows.forEach(r => {
                    const name = r.getAttribute("data-name") || "";
                    const catText = r.getAttribute("data-category") || "";
                    const catLower = r.getAttribute("data-category-lower") || "";

                    const matchSearch = !q || name.includes(q) || catLower.includes(q);
                    const matchCategory = !cat || catText === cat;

                    const show = matchSearch && matchCategory;
                    r.style.display = show ? "" : "none";

                    if (show) {
                        visible++;
                        if (isLowStockRow(r)) lowVisible++;
                    }
                });

                countTotal.textContent = visible.toString();
                countLow.textContent = lowVisible.toString();
            }

            searchInput.addEventListener("input", applyFilters);
            categoryFilter.addEventListener("change", applyFilters);

            clearBtn.addEventListener("click", () => {
                searchInput.value = "";
                categoryFilter.value = "";
                applyFilters();
            });

            applyFilters();
        })();
    </script>
}