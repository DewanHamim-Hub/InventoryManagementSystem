@model IMS.Models.Product

@{
    ViewData["Title"] = "Delete Product";
    var isLow = Model.Quantity <= Model.Threshold;
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="text-white mb-1">Delete Product</h2>
        <div class="ims-muted">This action cannot be undone.</div>
    </div>

    <a class="btn btn-outline-light" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card ims-card p-3 p-md-4">
            <div class="alert alert-danger mb-4">
                <div class="d-flex align-items-start gap-2">
                    <div class="fs-4">
                        <i class="bi bi-exclamation-octagon"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Confirm deletion</div>
                        <div class="small">
                            You are about to permanently delete this product from the inventory.
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                <div>
                    <div class="fw-semibold text-white fs-4">@Model.Name</div>
                    <div class="ims-muted">Category: @Model.Category</div>
                    <div class="ims-muted small">Product ID: @Model.ProductID</div>
                </div>

                <div>
                    @if (isLow)
                    {
                        <span class="badge rounded-pill bg-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>LOW STOCK
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-success">
                            <i class="bi bi-check2-circle me-1"></i>IN STOCK
                        </span>
                    }
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="ims-muted small mb-1">Unit Price</div>
                    <div class="text-white fs-5">৳ @Model.UnitPrice.ToString("0.00")</div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="ims-muted small mb-1">Quantity</div>
                    <div class="text-white fs-5">@Model.Quantity</div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="ims-muted small mb-1">Threshold</div>
                    <div class="text-white fs-5">@Model.Threshold</div>
                </div>
            </div>

            <hr class="border border-white border-opacity-10 my-4" />

            <form asp-action="Delete" method="post" class="d-flex flex-wrap gap-2">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductID" />

                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Yes, Delete Product
                </button>

                <a class="btn btn-outline-light" asp-action="Index">
                    Cancel
                </a>

                <a class="btn btn-outline-light ms-auto" asp-action="Details" asp-route-id="@Model.ProductID">
                    <i class="bi bi-eye me-1"></i>View Details
                </a>
            </form>

            <div class="mt-3 ims-muted small">
                Tip: If you only want to reduce stock, record a Sale instead of deleting the product.
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card ims-card p-3 p-md-4">
            <div class="fw-semibold text-white mb-2">
                <i class="bi bi-shield-exclamation me-1"></i>Warning
            </div>

            <ul class="ims-muted mb-0">
                <li class="mb-2">Deleting removes it from the Products list.</li>
                <li class="mb-2">If you have sales/restocks history linked, deletion may fail due to relationships.</li>
                <li>If that happens, you should keep the product and manage it via stock changes.</li>
            </ul>
        </div>
    </div>
</div>