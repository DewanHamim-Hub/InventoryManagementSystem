@model IMS.Models.Product

@{
    ViewData["Title"] = "Product Details";
    var isManager = User.IsInRole("Manager");
    var isLow = Model.Quantity <= Model.Threshold;
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="text-white mb-1">Product Details</h2>
        <div class="ims-muted">Full information and current stock status.</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-light" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>

        @if (isManager)
        {
            <a class="btn btn-outline-light" asp-action="Edit" asp-route-id="@Model.ProductID">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.ProductID">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="card ims-card p-3 p-md-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
                <div>
                    <div class="fw-semibold text-white fs-4">@Model.Name</div>
                    <div class="ims-muted">Category: @Model.Category</div>
                </div>

                <div>
                    @if (isLow)
                    {
                        <span class="badge rounded-pill bg-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i>LOW STOCK
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-success">
                            <i class="bi bi-check2-circle me-1"></i>IN STOCK
                        </span>
                    }
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <div class="ims-muted small mb-1">Unit Price</div>
                    <div class="text-white fs-5">৳ @Model.UnitPrice.ToString("0.00")</div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="ims-muted small mb-1">Product ID</div>
                    <div class="text-white fs-5">@Model.ProductID</div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="ims-muted small mb-1">Current Quantity</div>
                    <div class="text-white fs-5">@Model.Quantity</div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="ims-muted small mb-1">Threshold</div>
                    <div class="text-white fs-5">@Model.Threshold</div>
                </div>
            </div>

            <hr class="border border-white border-opacity-10 my-4" />

            <div class="ims-muted small">
                Stock quantity is adjusted automatically by recording Sales and Restocks.
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card ims-card p-3 p-md-4">
            <div class="fw-semibold text-white mb-2">
                <i class="bi bi-lightning me-1"></i>Quick Actions
            </div>

            <div class="d-grid gap-2">
                <a class="btn btn-primary" asp-controller="Sales" asp-action="Create">
                    <i class="bi bi-receipt me-1"></i>Record Sale
                </a>
                <a class="btn btn-outline-light" asp-controller="Restocks" asp-action="Create">
                    <i class="bi bi-truck me-1"></i>Record Restock
                </a>
                <a class="btn btn-outline-light" asp-controller="Search" asp-action="Index">
                    <i class="bi bi-search me-1"></i>Search Logs
                </a>
            </div>

            <hr class="border border-white border-opacity-10 my-4" />

            @if (isLow)
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Low stock warning: quantity is at or below threshold.
                </div>
            }
            else
            {
                <div class="alert alert-success mb-0">
                    <i class="bi bi-check2-circle me-1"></i>
                    Stock is healthy.
                </div>
            }
        </div>
    </div>
</div>