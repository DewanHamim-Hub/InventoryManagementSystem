@model IMS.Models.Restock

@{
    ViewData["Title"] = "Edit Restock";
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="text-white mb-1">Edit Restock</h2>
        <div class="ims-muted">Adjust quantity or product selection. Stock updates automatically.</div>
    </div>

    <a class="btn btn-outline-light" asp-action="Index">
        <i class="bi bi-arrow-left me-1"></i>Back to Restocks
    </a>
</div>

<div class="card ims-card p-3 p-md-4">
    <form asp-action="Edit" method="post" class="mt-1">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="RestockID" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">Product</label>
                <select asp-for="ProductID" class="form-select" asp-items="ViewBag.ProductID"></select>
                <span asp-validation-for="ProductID" class="text-danger small"></span>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">Quantity Added</label>
                <input asp-for="QuantityAdded" class="form-control" type="number" min="1" step="1" />
                <span asp-validation-for="QuantityAdded" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save me-1"></i>Save Changes
            </button>

            <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
        </div>

        <div class="mt-3 ims-muted small">
            Note: Restock date and recorded user remain unchanged.
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}